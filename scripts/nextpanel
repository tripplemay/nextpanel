#!/usr/bin/env bash
set -euo pipefail

# ============================================================================
#  NextPanel CLI — 面板管理工具
# ============================================================================

APP_DIR="/opt/apps/nextpanel"
BACKUP_DIR="/opt/backups/nextpanel"
LOG_DIR="/var/log/nextpanel"
MAX_BACKUPS=5

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()  { echo -e "${CYAN}[信息]${NC} $*"; }
ok()    { echo -e "${GREEN}[完成]${NC} $*"; }
warn()  { echo -e "${YELLOW}[警告]${NC} $*"; }
fail()  { echo -e "${RED}[错误]${NC} $*"; exit 1; }

check_root() {
  [ "$EUID" -eq 0 ] || fail "请以 root 用户运行：sudo nextpanel $*"
}

check_install() {
  [ -d "$APP_DIR/.git" ] || fail "未检测到 NextPanel 安装目录：$APP_DIR"
}

# ── status ─────────────────────────────────────────────────────────────────

cmd_status() {
  check_install

  echo ""
  echo "=========================================="
  echo "          NextPanel 服务状态"
  echo "=========================================="
  echo ""

  # PM2 进程
  echo "服务列表："
  pm2 list 2>/dev/null || warn "PM2 未运行"
  echo ""

  # 健康检查
  echo "健康检查："
  if curl -sf http://127.0.0.1:3001/api/docs > /dev/null 2>&1; then
    echo -e "  后端 (3001)：${GREEN}正常${NC}"
  else
    echo -e "  后端 (3001)：${RED}异常${NC}"
  fi
  if curl -sf http://127.0.0.1:3400/ > /dev/null 2>&1; then
    echo -e "  前端 (3400)：${GREEN}正常${NC}"
  else
    echo -e "  前端 (3400)：${RED}异常${NC}"
  fi
  echo ""

  # Nginx
  echo -n "  Nginx：       "
  if systemctl is-active nginx > /dev/null 2>&1; then
    echo -e "${GREEN}运行中${NC}"
  else
    echo -e "${RED}已停止${NC}"
  fi

  # PostgreSQL
  echo -n "  PostgreSQL：  "
  if systemctl is-active postgresql > /dev/null 2>&1; then
    echo -e "${GREEN}运行中${NC}"
  else
    echo -e "${RED}已停止${NC}"
  fi
  echo ""

  # SSL 证书
  if [ -f "$APP_DIR/apps/server/.env" ]; then
    PANEL_URL=$(grep '^PANEL_URL=' "$APP_DIR/apps/server/.env" | cut -d'"' -f2)
    echo "  面板地址：$PANEL_URL"
  fi

  DOMAIN_CONF="/etc/nginx/sites-available/nextpanel"
  if [ -f "$DOMAIN_CONF" ]; then
    DOMAIN=$(grep 'server_name' "$DOMAIN_CONF" | head -1 | awk '{print $2}' | tr -d ';')
    if [ "$DOMAIN" != "_" ] && [ -d "/etc/letsencrypt/live/$DOMAIN" ]; then
      EXPIRY=$(openssl x509 -enddate -noout -in "/etc/letsencrypt/live/$DOMAIN/fullchain.pem" 2>/dev/null | cut -d= -f2)
      echo "  SSL 证书：$DOMAIN（到期时间 $EXPIRY）"
    fi
  fi
  echo ""

  # 资源
  echo "资源使用："
  echo "  内存：$(free -h | awk '/^Mem/ {printf "%s / %s", $3, $2}')"
  echo "  磁盘：$(df -h "$APP_DIR" | awk 'NR==2 {printf "%s / %s（已用 %s）", $3, $2, $5}')"
  echo ""
}

# ── update ─────────────────────────────────────────────────────────────────

cmd_update() {
  check_root
  check_install

  BRANCH="${1:-main}"

  echo ""
  info "正在更新 NextPanel（分支：$BRANCH）..."
  echo ""

  # 步骤 1：备份数据库
  info "正在备份数据库..."
  cmd_backup_quiet

  # 步骤 2：拉取最新代码
  info "正在拉取最新代码..."
  cd "$APP_DIR"
  git fetch origin "$BRANCH" --depth 1 > /dev/null 2>&1
  git reset --hard "origin/$BRANCH" > /dev/null 2>&1
  ok "代码已更新"

  # 步骤 3：安装依赖
  info "正在安装依赖..."
  pnpm install --no-frozen-lockfile > /dev/null 2>&1
  cd "$APP_DIR/apps/server"
  pnpm exec prisma generate > /dev/null 2>&1
  ok "依赖安装完成"

  # 步骤 4：编译构建
  info "正在编译构建..."
  export NODE_OPTIONS="--max-old-space-size=1024"
  export NEXT_TELEMETRY_DISABLED=1
  BUILD_LOG="/tmp/nextpanel-build.log"

  cd "$APP_DIR/packages/shared" && pnpm build >> "$BUILD_LOG" 2>&1 || true
  cd "$APP_DIR/apps/server" && pnpm build >> "$BUILD_LOG" 2>&1
  if [ ! -f "$APP_DIR/apps/server/dist/main.js" ] || [ ! -s "$APP_DIR/apps/server/dist/main.js" ]; then
    tail -20 "$BUILD_LOG"
    fail "后端编译失败：dist/main.js 不存在或为空"
  fi

  cd "$APP_DIR/apps/web" && pnpm build >> "$BUILD_LOG" 2>&1
  if [ ! -d "$APP_DIR/apps/web/.next" ]; then
    tail -20 "$BUILD_LOG"
    fail "前端编译失败：.next 目录不存在"
  fi

  rm -f "$BUILD_LOG"
  unset NODE_OPTIONS NEXT_TELEMETRY_DISABLED
  ok "编译构建完成"

  # 步骤 5：数据库迁移
  info "正在执行数据库迁移..."
  cd "$APP_DIR/apps/server"
  MIGRATE_OUTPUT=$(pnpm exec prisma migrate deploy 2>&1) || {
    echo "$MIGRATE_OUTPUT"
    fail "数据库迁移失败"
  }
  ok "数据库迁移完成"

  # 步骤 6：更新 CLI 工具
  if [ -f "$APP_DIR/scripts/nextpanel" ]; then
    cp "$APP_DIR/scripts/nextpanel" /usr/local/bin/nextpanel
    chmod +x /usr/local/bin/nextpanel
    ok "CLI 工具已更新"
  fi

  # 步骤 7：重启服务
  info "正在重启服务..."
  cd "$APP_DIR"
  pm2 restart ecosystem.config.cjs > /dev/null 2>&1
  pm2 save > /dev/null 2>&1
  ok "服务已重启"

  sleep 5
  echo ""
  ok "更新完成！"
  pm2 list
  echo ""
}

# ── backup ─────────────────────────────────────────────────────────────────

cmd_backup_quiet() {
  mkdir -p "$BACKUP_DIR"
  TIMESTAMP=$(date +%Y%m%d_%H%M%S)
  BACKUP_FILE="$BACKUP_DIR/nextpanel_${TIMESTAMP}.sql.gz"

  sudo -u postgres pg_dump nextpanel 2>/dev/null | gzip > "$BACKUP_FILE"

  # 轮转：只保留最近 MAX_BACKUPS 份
  ls -t "$BACKUP_DIR"/nextpanel_*.sql.gz 2>/dev/null | tail -n +$((MAX_BACKUPS + 1)) | xargs rm -f 2>/dev/null || true

  ok "数据库已备份：$BACKUP_FILE"
}

cmd_backup() {
  check_root
  check_install

  echo ""
  info "正在备份 NextPanel 数据库..."
  cmd_backup_quiet

  echo ""
  echo "备份列表（最近 $MAX_BACKUPS 份）："
  ls -lh "$BACKUP_DIR"/nextpanel_*.sql.gz 2>/dev/null | awk '{print "  " $NF " (" $5 ")"}'
  echo ""
}

# ── restore ────────────────────────────────────────────────────────────────

cmd_restore() {
  check_root
  check_install

  BACKUP_FILE="${1:-}"
  [ -n "$BACKUP_FILE" ] || fail "用法：nextpanel restore <备份文件.sql.gz>"
  [ -f "$BACKUP_FILE" ] || fail "备份文件不存在：$BACKUP_FILE"

  # 验证备份文件完整性
  info "正在验证备份文件..."
  if ! gunzip -t "$BACKUP_FILE" 2>/dev/null; then
    fail "备份文件损坏（gzip 校验失败）"
  fi
  ok "备份文件验证通过"

  echo ""
  warn "此操作将用备份文件替换当前数据库。"
  read -rp "确认继续？[y/N]：" CONFIRM
  [ "$CONFIRM" = "y" ] || [ "$CONFIRM" = "Y" ] || fail "已取消"

  # 安全备份
  info "正在备份当前数据库（安全措施）..."
  cmd_backup_quiet

  info "正在停止服务..."
  pm2 stop nextpanel-server > /dev/null 2>&1 || true
  pm2 stop nextpanel-web > /dev/null 2>&1 || true

  info "正在恢复数据库..."
  sudo -u postgres dropdb nextpanel --if-exists 2>/dev/null
  sudo -u postgres createdb nextpanel -O nextpanel 2>/dev/null
  gunzip < "$BACKUP_FILE" | sudo -u postgres psql -d nextpanel > /dev/null 2>&1
  if [ $? -ne 0 ]; then
    warn "恢复失败，正在回滚到安全备份..."
    # Find the latest safety backup (the one we just created before restore)
    SAFETY_BACKUP=$(ls -t "$BACKUP_DIR"/nextpanel_*.sql.gz 2>/dev/null | head -1)
    if [ -n "$SAFETY_BACKUP" ] && [ "$SAFETY_BACKUP" != "$BACKUP_FILE" ]; then
      sudo -u postgres dropdb nextpanel --if-exists 2>/dev/null
      sudo -u postgres createdb nextpanel -O nextpanel 2>/dev/null
      if gunzip < "$SAFETY_BACKUP" | sudo -u postgres psql -d nextpanel > /dev/null 2>&1; then
        ok "已回滚到安全备份：$SAFETY_BACKUP"
      else
        fail "回滚也失败了，数据库可能处于不一致状态，请手动恢复"
      fi
    else
      fail "未找到可用的安全备份进行回滚，数据库可能处于不一致状态"
    fi
    fail "数据库恢复失败，已回滚到恢复前的状态"
  fi
  ok "数据库已恢复"

  info "正在重启服务..."
  cd "$APP_DIR"
  pm2 restart ecosystem.config.cjs > /dev/null 2>&1
  pm2 save > /dev/null 2>&1

  sleep 5
  ok "恢复完成！"
  echo ""
}

# ── domain set ─────────────────────────────────────────────────────────────

cmd_domain_set() {
  check_root
  check_install

  DOMAIN="${1:-}"
  [ -n "$DOMAIN" ] || fail "用法：nextpanel domain set <域名> [--email <邮箱>]"

  EMAIL=""
  shift
  while [ $# -gt 0 ]; do
    case "$1" in
      --email) EMAIL="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  if [ -z "$EMAIL" ]; then
    read -rp "请输入邮箱（用于 SSL 证书申请）：" EMAIL
    [ -n "$EMAIL" ] || fail "邮箱不能为空"
  fi

  echo ""
  info "正在绑定域名：$DOMAIN"

  # 验证 DNS
  info "正在验证 DNS 解析..."
  SERVER_IP=$(hostname -I | awk '{print $1}')
  RESOLVED_IP=$(dig +short "$DOMAIN" 2>/dev/null | head -1)
  if [ "$RESOLVED_IP" != "$SERVER_IP" ]; then
    warn "DNS 不匹配：$DOMAIN 解析到 ${RESOLVED_IP:-无结果}，本机 IP 为 $SERVER_IP"
    read -rp "是否继续？[y/N]：" DNS_CONTINUE
    [ "$DNS_CONTINUE" = "y" ] || [ "$DNS_CONTINUE" = "Y" ] || fail "已取消"
  else
    ok "DNS 验证通过：$DOMAIN -> $SERVER_IP"
  fi

  # 检测并禁用冲突的 Nginx 配置
  CONFLICT=$(grep -rl "server_name.*$DOMAIN" /etc/nginx/sites-enabled/ 2>/dev/null | grep -v nextpanel || true)
  if [ -n "$CONFLICT" ]; then
    warn "域名 $DOMAIN 已存在于其他配置中：$CONFLICT"
    warn "正在禁用冲突配置..."
    for f in $CONFLICT; do
      rm -f "$f"
      ok "已禁用：$f"
    done
  fi

  # 更新 Nginx 配置
  info "正在更新 Nginx 配置..."
  sed "s/DOMAIN_PLACEHOLDER/$DOMAIN/g" "$APP_DIR/scripts/nginx/domain.conf" \
    > /etc/nginx/sites-available/nextpanel
  ln -sf /etc/nginx/sites-available/nextpanel /etc/nginx/sites-enabled/
  nginx -t > /dev/null 2>&1 || fail "Nginx 配置测试失败"
  systemctl reload nginx
  ok "Nginx 配置已更新"

  # 申请 SSL 证书
  info "正在申请 SSL 证书..."
  if certbot --nginx -d "$DOMAIN" --non-interactive --agree-tos -m "$EMAIL" > /dev/null 2>&1; then
    systemctl enable certbot.timer > /dev/null 2>&1 || true
    ok "SSL 证书已安装"
  else
    fail "SSL 证书申请失败，请检查 80 端口是否可访问且 DNS 解析正确。"
  fi

  # 更新 .env
  info "正在更新配置文件..."
  ENV_FILE="$APP_DIR/apps/server/.env"
  sed -i "s|^ALLOWED_ORIGIN=.*|ALLOWED_ORIGIN=\"https://$DOMAIN\"|" "$ENV_FILE"
  sed -i "s|^PANEL_URL=.*|PANEL_URL=\"https://$DOMAIN\"|" "$ENV_FILE"
  ok "配置文件已更新"

  # 重启服务
  info "正在重启服务..."
  cd "$APP_DIR"
  pm2 restart ecosystem.config.cjs > /dev/null 2>&1
  pm2 save > /dev/null 2>&1

  sleep 5
  echo ""
  ok "域名绑定成功！"
  echo ""
  echo -e "  面板地址：${CYAN}https://$DOMAIN${NC}"
  echo ""
}

# ── logs ───────────────────────────────────────────────────────────────────

cmd_logs() {
  SERVICE="${1:-all}"
  LINES="${2:-50}"

  case "$SERVICE" in
    server) pm2 logs nextpanel-server --lines "$LINES" --nostream ;;
    web)    pm2 logs nextpanel-web --lines "$LINES" --nostream ;;
    all|*)  pm2 logs --lines "$LINES" --nostream ;;
  esac
}

# ── fix-nginx ──────────────────────────────────────────────────────────────

cmd_fix_nginx() {
  check_root
  check_install

  echo ""
  info "修复 Nginx 配置（移除 default_server，与其他站点共存）"
  echo ""

  # 读取当前 .env 获取配置信息
  ENV_FILE="$APP_DIR/apps/server/.env"
  PANEL_URL=$(grep '^PANEL_URL=' "$ENV_FILE" 2>/dev/null | cut -d'"' -f2)

  if [[ "$PANEL_URL" == https://* ]]; then
    # 域名模式：从 URL 提取域名
    DOMAIN=$(echo "$PANEL_URL" | sed 's|https://||')
    info "检测到域名模式：$DOMAIN"

    # 检测冲突配置
    CONFLICT=$(grep -rl "server_name.*$DOMAIN" /etc/nginx/sites-enabled/ 2>/dev/null | grep -v nextpanel || true)
    if [ -n "$CONFLICT" ]; then
      warn "域名 $DOMAIN 存在于其他配置中：$CONFLICT"
      warn "正在禁用冲突配置..."
      for f in $CONFLICT; do
        rm -f "$f"
        ok "已禁用：$f"
      done
    fi

    # 用新模板覆盖（不含 default_server）
    sed "s/DOMAIN_PLACEHOLDER/$DOMAIN/g" "$APP_DIR/scripts/nginx/domain.conf" \
      > /etc/nginx/sites-available/nextpanel

    # 如果有 SSL 证书，让 Certbot 重新注入 SSL 配置
    if [ -d "/etc/letsencrypt/live/$DOMAIN" ]; then
      ln -sf /etc/nginx/sites-available/nextpanel /etc/nginx/sites-enabled/
      nginx -t > /dev/null 2>&1 || fail "Nginx 配置测试失败"
      systemctl reload nginx
      certbot --nginx -d "$DOMAIN" --non-interactive --reinstall > /dev/null 2>&1 || warn "Certbot 重新注入失败，HTTPS 可能需要手动修复"
    fi
  else
    # IP 模式：从 URL 提取 IP
    SERVER_IP=$(echo "$PANEL_URL" | sed 's|http://||')
    info "检测到 IP 模式：$SERVER_IP"

    sed "s/IP_PLACEHOLDER/$SERVER_IP/g" "$APP_DIR/scripts/nginx/ip.conf" \
      > /etc/nginx/sites-available/nextpanel
  fi

  ln -sf /etc/nginx/sites-available/nextpanel /etc/nginx/sites-enabled/
  nginx -t > /dev/null 2>&1 || fail "Nginx 配置测试失败"
  systemctl reload nginx

  echo ""
  ok "Nginx 配置已修复！"
  echo ""
  echo "  NextPanel 现在使用独立的 server_name，不再占用 default_server。"
  echo "  如果您的其他网站配置之前被删除，请手动恢复并放到 /etc/nginx/sites-enabled/ 下。"
  echo ""
}

# ── uninstall ──────────────────────────────────────────────────────────────

cmd_uninstall() {
  check_root
  check_install

  echo ""
  warn "此操作将从服务器上完全移除 NextPanel。"
  read -rp "卸载前是否创建最终备份？[Y/n]：" DO_BACKUP
  if [ "$DO_BACKUP" != "n" ] && [ "$DO_BACKUP" != "N" ]; then
    cmd_backup_quiet
  fi

  read -rp "请输入 'UNINSTALL' 确认卸载：" CONFIRM
  [ "$CONFIRM" = "UNINSTALL" ] || fail "已取消"

  echo ""
  info "正在停止服务..."
  pm2 stop nextpanel-server > /dev/null 2>&1 || true
  pm2 stop nextpanel-web > /dev/null 2>&1 || true
  pm2 delete nextpanel-server > /dev/null 2>&1 || true
  pm2 delete nextpanel-web > /dev/null 2>&1 || true

  info "正在移除 Nginx 配置..."
  rm -f /etc/nginx/sites-enabled/nextpanel
  rm -f /etc/nginx/sites-available/nextpanel
  systemctl reload nginx > /dev/null 2>&1 || true

  info "正在删除数据库..."
  sudo -u postgres dropdb nextpanel --if-exists 2>/dev/null || true
  sudo -u postgres psql -c "DROP USER IF EXISTS nextpanel;" > /dev/null 2>&1 || true

  info "正在删除应用文件..."
  rm -rf "$APP_DIR"
  rm -rf "$LOG_DIR"

  info "正在移除 CLI 工具..."
  rm -f /usr/local/bin/nextpanel

  echo ""
  ok "NextPanel 已卸载。"
  if [ -d "$BACKUP_DIR" ]; then
    echo ""
    echo "  数据库备份已保留在：$BACKUP_DIR"
    echo "  如不需要请手动删除：rm -rf $BACKUP_DIR"
  fi
  echo ""
}

# ── help ───────────────────────────────────────────────────────────────────

cmd_help() {
  echo ""
  echo "NextPanel 面板管理工具"
  echo ""
  echo "用法：nextpanel <命令> [选项]"
  echo ""
  echo "命令："
  echo "  status                    查看服务状态和健康检查"
  echo "  update [分支]              更新到最新版本（默认：main）"
  echo "  backup                    备份数据库"
  echo "  restore <文件>             从备份恢复数据库"
  echo "  domain set <域名>          绑定域名并自动申请 SSL 证书"
  echo "  fix-nginx                 修复 Nginx 配置（与其他站点共存）"
  echo "  logs [server|web] [行数]   查看服务日志"
  echo "  uninstall                 卸载 NextPanel"
  echo "  help                      显示此帮助信息"
  echo ""
}

# ── 主路由 ─────────────────────────────────────────────────────────────────

case "${1:-help}" in
  status)     cmd_status ;;
  update)     shift; cmd_update "$@" ;;
  backup)     cmd_backup ;;
  restore)    shift; cmd_restore "$@" ;;
  domain)
    shift
    case "${1:-}" in
      set) shift; cmd_domain_set "$@" ;;
      *)   fail "用法：nextpanel domain set <域名> [--email <邮箱>]" ;;
    esac
    ;;
  fix-nginx)  cmd_fix_nginx ;;
  logs)       shift; cmd_logs "$@" ;;
  uninstall)  cmd_uninstall ;;
  help|*)     cmd_help ;;
esac
