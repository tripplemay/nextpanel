generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────── User ────────────────────────────

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         UserRole @default(VIEWER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs         AuditLog[]
  subscriptions     Subscription[]
  servers           Server[]
  nodes             Node[]
  cloudflareSetting CloudflareSetting?
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

// ──────────────────────────── Server ────────────────────────────

model Server {
  id           String       @id @default(cuid())
  /// Resource owner — nullable during migration, required once multi-tenancy is enforced
  owner        User?        @relation(fields: [userId], references: [id])
  userId       String?
  name         String
  region       String
  provider     String
  ip           String
  sshPort      Int          @default(22)
  sshUser      String       @default("root")
  sshAuthType  SshAuthType  @default(KEY)
  /// AES-GCM encrypted ssh key or password
  sshAuthEnc   String
  tags         String[]
  notes        String?
  status       ServerStatus @default(UNKNOWN)
  cpuUsage     Float?
  memUsage     Float?
  diskUsage    Float?
  networkIn    Float?
  networkOut   Float?
  pingMs       Int?
  lastSeenAt   DateTime?
  agentVersion String?
  agentToken   String       @unique @default(cuid())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  nodes        Node[]
  metrics      ServerMetric[]

  @@index([userId])
}

enum SshAuthType {
  KEY
  PASSWORD
}

enum ServerStatus {
  UNKNOWN
  ONLINE
  OFFLINE
  ERROR
}

// ──────────────────────────── Node ────────────────────────────

model Node {
  id             String          @id @default(cuid())
  server         Server          @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId       String
  /// Resource owner — nullable during migration, required once multi-tenancy is enforced
  owner          User?           @relation(fields: [userId], references: [id])
  userId         String?
  name           String
  protocol       Protocol
  implementation Implementation?
  transport      Transport?
  tls            TlsMode         @default(NONE)
  listenPort     Int
  domain         String?
  /// AES-GCM encrypted JSON credentials
  credentialsEnc String
  /// Cloudflare DNS record ID — set for VLESS+WS+TLS nodes, used for cleanup on delete
  cfDnsRecordId  String?
  source         NodeSource      @default(MANUAL)
  status         NodeStatus      @default(INACTIVE)
  enabled        Boolean         @default(true)
  /// Last connectivity test: true = reachable, false = unreachable, null = never tested
  lastReachable    Boolean?
  /// Last measured latency in ms
  lastLatency      Int?
  /// Timestamp of last connectivity test
  lastTestedAt     DateTime?
  /// xray stats API port — set only for deployed xray/v2ray nodes; null for sing-box/ss-libev
  statsPort        Int?
  /// Cumulative upload bytes since last deploy (xray nodes only) — reset on redeploy
  trafficUpBytes   Float           @default(0)
  /// Cumulative download bytes since last deploy (xray nodes only) — reset on redeploy
  trafficDownBytes Float           @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  snapshots         ConfigSnapshot[]
  subscriptionNodes SubscriptionNode[]

  @@index([userId])
}

enum Protocol {
  VMESS
  VLESS
  TROJAN
  SHADOWSOCKS
  SOCKS5
  HTTP
  HYSTERIA2
}

enum Implementation {
  XRAY
  V2RAY
  SING_BOX
  SS_LIBEV
}

enum Transport {
  TCP
  WS
  GRPC
  QUIC
}

enum TlsMode {
  NONE
  TLS
  REALITY
}

enum NodeStatus {
  INACTIVE
  RUNNING
  STOPPED
  ERROR
}

enum NodeSource {
  MANUAL
  AUTO
}

// ──────────────────────────── ConfigSnapshot ────────────────────────────

model ConfigSnapshot {
  id        String   @id @default(cuid())
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  nodeId    String
  version   Int
  /// Full rendered config content
  content   String
  checksum  String
  /// Full deployment log text (newline-separated)
  deployLog String?
  createdAt DateTime @default(now())

  @@unique([nodeId, version])
}

// ──────────────────────────── ServerMetric ────────────────────────────

model ServerMetric {
  id         String   @id @default(cuid())
  server     Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId   String
  cpu        Float
  mem        Float
  disk       Float
  networkIn  Float
  networkOut Float
  timestamp  DateTime @default(now())

  @@index([serverId, timestamp])
}

// ──────────────────────────── Subscription ────────────────────────────

model Subscription {
  id        String   @id @default(cuid())
  name      String
  token     String   @unique @default(cuid())
  owner     User     @relation(fields: [ownerId], references: [id])
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nodes SubscriptionNode[]
}

model SubscriptionNode {
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  subscriptionId String
  node           Node         @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  nodeId         String

  @@id([subscriptionId, nodeId])
}

// ──────────────────────────── AuditLog ────────────────────────────

model AuditLog {
  id            String      @id @default(cuid())
  actor         User        @relation(fields: [actorId], references: [id])
  actorId       String
  action        AuditAction
  resource      String
  resourceId    String?
  diff          Json?
  ip            String?
  /// Links to OperationLog.correlationId — set for SSH-related actions
  correlationId String?
  timestamp     DateTime    @default(now())

  @@index([actorId])
  @@index([timestamp])
  @@index([correlationId])
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  DEPLOY
  ROLLBACK
  SSH_TEST
}

// ──────────────────────────── OperationLog ────────────────────────────

model OperationLog {
  id            String   @id @default(cuid())
  /// Resource type — e.g. 'node', 'server', any future resource
  resourceType  String
  /// Nullable — resource may be deleted but log must persist
  resourceId    String?
  /// Denormalised resource name — survives resource deletion
  resourceName  String
  /// Nullable — system-triggered operations have no human actor
  actorId       String?
  /// Flexible operation name — e.g. 'DEPLOY', 'UNDEPLOY', any future operation
  operation     String
  /// Links to AuditLog.correlationId for join queries
  correlationId String?
  success       Boolean
  /// Full log text (newline-separated)
  log           String?
  /// Duration in milliseconds
  durationMs    Int?
  createdAt     DateTime @default(now())

  @@index([resourceType, resourceId])
  @@index([correlationId])
  @@index([createdAt])
}

// ──────────────────────────── CloudflareSetting ────────────────────────────

model CloudflareSetting {
  id          String   @id @default(cuid())
  /// Resource owner — one setting per user (unique)
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @unique
  /// AES-GCM encrypted Cloudflare API Token
  apiTokenEnc String
  /// Root domain managed by this Cloudflare account (e.g. example.com)
  domain      String
  /// Cloudflare Zone ID for the domain
  zoneId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
