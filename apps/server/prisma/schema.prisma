generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────── User ────────────────────────────

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  passwordHash  String
  role          UserRole  @default(VIEWER)
  wxWorkUserId  String?   @unique
  wxWorkName    String?
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  auditLogs              AuditLog[]
  subscriptions          Subscription[]
  subscriptionShares     SubscriptionShare[]
  servers                Server[]
  nodes                  Node[]
  externalNodes          ExternalNode[]
  cloudflareSetting      CloudflareSetting?
  inviteCodes            InviteCode[]
}

model RevokedToken {
  jti       String   @id
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// ──────────────────────────── InviteCode ────────────────────────────

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique @default(cuid())
  maxUses   Int      @default(1)
  usedCount Int      @default(0)
  creator   User     @relation(fields: [createdBy], references: [id])
  createdBy String
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

// ──────────────────────────── Server ────────────────────────────

model Server {
  id           String       @id @default(cuid())
  owner        User         @relation(fields: [userId], references: [id])
  userId       String
  name         String
  region       String
  countryCode  String?
  provider     String
  ip           String
  sshPort      Int          @default(22)
  sshUser      String       @default("root")
  sshAuthType  SshAuthType  @default(KEY)
  /// AES-GCM encrypted ssh key or password
  sshAuthEnc   String
  tags         String[]
  autoTags     String[]
  notes        String?
  status       ServerStatus @default(UNKNOWN)
  cpuUsage     Float?
  memUsage     Float?
  diskUsage    Float?
  networkIn    Float?
  networkOut   Float?
  pingMs       Int?
  lastSeenAt          DateTime?
  agentVersion        String?
  agentToken          String       @unique @default(cuid())
  pendingAgentUpdate  Boolean      @default(false)
  deleteError         String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  nodes            Node[]
  chainExitNodes   Node[]         @relation("chainExitServer")
  metrics          ServerMetric[]
  ipCheck          ServerIpCheck?

  @@index([userId])
}

enum SshAuthType {
  KEY
  PASSWORD
}

enum ServerStatus {
  UNKNOWN
  ONLINE
  OFFLINE
  DELETING
  ERROR
}

// ──────────────────────────── Node ────────────────────────────

model Node {
  id             String          @id @default(cuid())
  server         Server          @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId       String
  owner          User            @relation(fields: [userId], references: [id])
  userId         String
  name           String
  protocol       Protocol
  implementation Implementation?
  transport      Transport?
  tls            TlsMode         @default(NONE)
  listenPort     Int
  domain         String?
  /// AES-GCM encrypted JSON credentials
  credentialsEnc String
  /// Cloudflare DNS record ID — set for VLESS+WS+TLS nodes, used for cleanup on delete
  cfDnsRecordId  String?
  source         NodeSource      @default(MANUAL)
  status         NodeStatus      @default(INACTIVE)
  enabled        Boolean         @default(true)
  /// Last connectivity test: true = reachable, false = unreachable, null = never tested
  lastReachable    Boolean?
  /// Last measured latency in ms
  lastLatency      Int?
  /// Timestamp of last connectivity test
  lastTestedAt     DateTime?
  /// xray stats API port — set only for deployed xray/v2ray nodes; null for sing-box/ss-libev
  statsPort        Int?
  /// Cumulative upload bytes since last deploy (xray nodes only) — reset on redeploy
  trafficUpBytes   Float           @default(0)
  /// Cumulative download bytes since last deploy (xray nodes only) — reset on redeploy
  trafficDownBytes Float           @default(0)
  /// Chain proxy: exit server (when set, this is a chain node — entry on this server, exit on exitServer)
  exitServer       Server?         @relation("chainExitServer", fields: [exitServerId], references: [id])
  exitServerId     String?
  /// Chain proxy: port on exit server for dokodemo-door / internal VLESS
  exitPort         Int?
  /// Chain proxy: UUID for internal VLESS between entry and exit (AES-GCM encrypted)
  chainCredEnc     String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  snapshots         ConfigSnapshot[]
  subscriptionNodes SubscriptionNode[]

  @@index([userId])
}

enum Protocol {
  VMESS
  VLESS
  TROJAN
  SHADOWSOCKS
  SOCKS5
  HTTP
  HYSTERIA2
}

enum Implementation {
  XRAY
  V2RAY
  SING_BOX
  SS_LIBEV
}

enum Transport {
  TCP
  WS
  GRPC
  QUIC
}

enum TlsMode {
  NONE
  TLS
  REALITY
}

enum NodeStatus {
  INACTIVE
  RUNNING
  STOPPED
  ERROR
}

enum NodeSource {
  MANUAL
  AUTO
}

// ──────────────────────────── ConfigSnapshot ────────────────────────────

model ConfigSnapshot {
  id        String   @id @default(cuid())
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  nodeId    String
  version   Int
  /// Full rendered config content
  content   String
  checksum  String
  /// Full deployment log text (newline-separated)
  deployLog String?
  createdAt DateTime @default(now())

  @@unique([nodeId, version])
}

// ──────────────────────────── ServerMetric ────────────────────────────

model ServerMetric {
  id         String   @id @default(cuid())
  server     Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId   String
  cpu        Float
  mem        Float
  disk       Float
  networkIn  Float
  networkOut Float
  timestamp  DateTime @default(now())

  @@index([serverId, timestamp])
}

// ──────────────────────────── Subscription ────────────────────────────

model Subscription {
  id        String   @id @default(cuid())
  name      String
  token     String   @unique @default(cuid())
  owner     User     @relation(fields: [ownerId], references: [id])
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nodes         SubscriptionNode[]
  externalNodes ExternalSubscriptionNode[]
  shares        SubscriptionShare[]
}

model SubscriptionShare {
  id             String       @id @default(cuid())
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  subscriptionId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  shareToken     String       @unique @default(cuid())
  createdAt      DateTime     @default(now())

  @@unique([subscriptionId, userId])
}

model SubscriptionNode {
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  subscriptionId String
  node           Node         @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  nodeId         String

  @@id([subscriptionId, nodeId])
}

// ──────────────────────────── ExternalNode ────────────────────────────

model ExternalNode {
  id            String   @id @default(cuid())
  owner         User     @relation(fields: [userId], references: [id])
  userId        String
  name          String
  protocol      String
  address       String
  port          Int
  uuid          String?
  password      String?
  method        String?
  transport     String?
  tls           String   @default("NONE")
  sni           String?
  path          String?
  rawUri        String?
  lastTestedAt  DateTime?
  lastReachable Boolean?
  lastLatency   Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptionNodes ExternalSubscriptionNode[]

  @@index([userId])
}

model ExternalSubscriptionNode {
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  subscriptionId String
  externalNode   ExternalNode @relation(fields: [externalNodeId], references: [id], onDelete: Cascade)
  externalNodeId String

  @@id([subscriptionId, externalNodeId])
}

// ──────────────────────────── AuditLog ────────────────────────────

model AuditLog {
  id            String      @id @default(cuid())
  actor         User        @relation(fields: [actorId], references: [id])
  actorId       String
  action        AuditAction
  resource      String
  resourceId    String?
  diff          Json?
  ip            String?
  /// Links to OperationLog.correlationId — set for SSH-related actions
  correlationId String?
  timestamp     DateTime    @default(now())

  @@index([actorId])
  @@index([timestamp])
  @@index([correlationId])
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  DEPLOY
  ROLLBACK
  SSH_TEST
}

// ──────────────────────────── OperationLog ────────────────────────────

model OperationLog {
  id            String   @id @default(cuid())
  /// Resource type — e.g. 'node', 'server', any future resource
  resourceType  String
  /// Nullable — resource may be deleted but log must persist
  resourceId    String?
  /// Denormalised resource name — survives resource deletion
  resourceName  String
  /// Nullable — system-triggered operations have no human actor
  actorId       String?
  /// Flexible operation name — e.g. 'DEPLOY', 'UNDEPLOY', any future operation
  operation     String
  /// Links to AuditLog.correlationId for join queries
  correlationId String?
  success       Boolean
  /// Full log text (newline-separated)
  log           String?
  /// Duration in milliseconds
  durationMs    Int?
  createdAt     DateTime @default(now())

  @@index([resourceType, resourceId])
  @@index([correlationId])
  @@index([createdAt])
}

// ──────────────────────────── RuleCache ────────────────────────────

model RuleCache {
  /// Rule name, e.g. "reject", "netflix"
  name      String   @id
  /// Raw text content fetched from upstream source
  content   String
  updatedAt DateTime @updatedAt
}

// ──────────────────────────── ServerIpCheck ────────────────────────────

model ServerIpCheck {
  id         String        @id @default(cuid())
  server     Server        @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId   String        @unique
  status     IpCheckStatus @default(PENDING)
  startedAt  DateTime?
  finishedAt DateTime?
  error      String?

  /// IP basic info — fetched directly by panel via ip-api.com / ipinfo.io
  ipType  String? /// RESIDENTIAL | DATACENTER
  asn     String? /// e.g. AS45102
  org     String? /// e.g. Alibaba Cloud
  country String? /// ISO 3166-1 alpha-2, e.g. SG
  city    String?

  /// Streaming / AI checks — executed by Agent on the server
  netflix        String? /// UNLOCKED | ORIGINALS_ONLY | BLOCKED
  netflixRegion  String?
  disney         String? /// AVAILABLE | BLOCKED
  disneyRegion   String?
  youtube        String? /// AVAILABLE | BLOCKED
  youtubeRegion  String?
  hulu           String? /// AVAILABLE | BLOCKED
  bilibili       String? /// AVAILABLE | BLOCKED
  openai         String? /// AVAILABLE | BLOCKED
  claude         String? /// AVAILABLE | BLOCKED
  gemini         String? /// AVAILABLE | BLOCKED

  /// GFW check — executed via Serverless function inside China
  gfwBlocked   Boolean?
  gfwCheckedAt DateTime?

  /// Route check — go/return path latency + traceroute to 9 Chinese ISP nodes
  /// Structure: { checkedAt, outbound: RouteNodeResult[], inbound: InboundResult[] }
  routeData Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum IpCheckStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ──────────────────────────── WxWorkSetting ────────────────────────────

model WxWorkSetting {
  id         String   @id @default(cuid())
  corpId     String
  agentId    String
  secretEnc  String
  proxyUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ──────────────────────────── OpenRouterSetting ────────────────────────────

model OpenRouterSetting {
  id         String   @id @default(cuid())
  apiKeyEnc  String
  model      String   @default("anthropic/claude-sonnet-4")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ──────────────────────────── ServerRecommend ────────────────────────────

model ServerRecommendCategory {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String?
  featuredId  String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recommends  ServerRecommendOnCategory[]
}

model ServerRecommend {
  id         String   @id @default(cuid())
  name       String
  price      String
  regions    String[]
  link       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  categories ServerRecommendOnCategory[]
}

model ServerRecommendOnCategory {
  category    ServerRecommendCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId  String
  recommend   ServerRecommend @relation(fields: [recommendId], references: [id], onDelete: Cascade)
  recommendId String

  @@id([categoryId, recommendId])
}

// ──────────────────────────── CloudflareSetting ────────────────────────────

model CloudflareSetting {
  id          String   @id @default(cuid())
  /// Resource owner — one setting per user (unique)
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @unique
  /// AES-GCM encrypted Cloudflare API Token
  apiTokenEnc String
  /// Root domain managed by this Cloudflare account (e.g. example.com)
  domain      String
  /// Cloudflare Zone ID for the domain
  zoneId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
