generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────── User ────────────────────────────

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         UserRole @default(VIEWER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs    AuditLog[]
  releases     Release[]
  templates    Template[]
  subscriptions Subscription[]
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

// ──────────────────────────── Server ────────────────────────────

model Server {
  id           String       @id @default(cuid())
  name         String
  region       String
  provider     String
  ip           String
  sshPort      Int          @default(22)
  sshUser      String       @default("root")
  sshAuthType  SshAuthType  @default(KEY)
  /// AES-GCM encrypted ssh key or password
  sshAuthEnc   String
  tags         String[]
  notes        String?
  status       ServerStatus @default(UNKNOWN)
  cpuUsage     Float?
  memUsage     Float?
  diskUsage    Float?
  networkIn    BigInt?
  networkOut   BigInt?
  pingMs       Int?
  lastSeenAt   DateTime?
  agentVersion String?
  agentToken   String       @unique @default(cuid())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  nodes        Node[]
  releaseSteps ReleaseStep[]
  metrics      ServerMetric[]
}

enum SshAuthType {
  KEY
  PASSWORD
}

enum ServerStatus {
  UNKNOWN
  ONLINE
  OFFLINE
  ERROR
}

// ──────────────────────────── Node ────────────────────────────

model Node {
  id             String          @id @default(cuid())
  server         Server          @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId       String
  name           String
  protocol       Protocol
  implementation Implementation?
  transport      Transport?
  tls            TlsMode         @default(NONE)
  listenPort     Int
  domain         String?
  /// AES-GCM encrypted JSON credentials
  credentialsEnc String
  source         NodeSource      @default(MANUAL)
  status         NodeStatus      @default(INACTIVE)
  enabled        Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  snapshots         ConfigSnapshot[]
  subscriptionNodes SubscriptionNode[]
}

enum Protocol {
  VMESS
  VLESS
  TROJAN
  SHADOWSOCKS
  SOCKS5
  HTTP
}

enum Implementation {
  XRAY
  V2RAY
  SING_BOX
  SS_LIBEV
}

enum Transport {
  TCP
  WS
  GRPC
  QUIC
}

enum TlsMode {
  NONE
  TLS
  REALITY
}

enum NodeStatus {
  INACTIVE
  RUNNING
  STOPPED
  ERROR
}

enum NodeSource {
  MANUAL
  AUTO
}

// ──────────────────────────── Template ────────────────────────────

model Template {
  id             String          @id @default(cuid())
  name           String
  protocol       Protocol
  implementation Implementation?
  description    String?
  /// JSON template with {{variable}} placeholders
  content        String
  variables      String[]
  createdBy      User            @relation(fields: [createdById], references: [id])
  createdById    String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  releases Release[]
}

// ──────────────────────────── Release ────────────────────────────

model Release {
  id          String          @id @default(cuid())
  template    Template        @relation(fields: [templateId], references: [id])
  templateId  String
  targets     String[]        // server IDs
  strategy    ReleaseStrategy @default(SINGLE)
  status      ReleaseStatus   @default(PENDING)
  /// JSON key-value of rendered variables
  variables   Json            @default("{}")
  createdBy   User            @relation(fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  steps ReleaseStep[]
}

enum ReleaseStrategy {
  SINGLE
  BATCH
  CANARY
}

enum ReleaseStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  ROLLED_BACK
}

model ReleaseStep {
  id        String            @id @default(cuid())
  release   Release           @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  releaseId String
  server    Server            @relation(fields: [serverId], references: [id])
  serverId  String
  status    ReleaseStepStatus @default(PENDING)
  log       String?
  startedAt DateTime?
  endedAt   DateTime?
}

enum ReleaseStepStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}

// ──────────────────────────── ConfigSnapshot ────────────────────────────

model ConfigSnapshot {
  id        String   @id @default(cuid())
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  nodeId    String
  version   Int
  /// Full rendered config content
  content   String
  checksum  String
  /// Full deployment log text (newline-separated)
  deployLog String?
  createdAt DateTime @default(now())

  @@unique([nodeId, version])
}

// ──────────────────────────── ServerMetric ────────────────────────────

model ServerMetric {
  id         String   @id @default(cuid())
  server     Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId   String
  cpu        Float
  mem        Float
  disk       Float
  networkIn  BigInt
  networkOut BigInt
  timestamp  DateTime @default(now())

  @@index([serverId, timestamp])
}

// ──────────────────────────── Subscription ────────────────────────────

model Subscription {
  id        String   @id @default(cuid())
  name      String
  token     String   @unique @default(cuid())
  owner     User     @relation(fields: [ownerId], references: [id])
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nodes SubscriptionNode[]
}

model SubscriptionNode {
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  subscriptionId String
  node           Node         @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  nodeId         String

  @@id([subscriptionId, nodeId])
}

// ──────────────────────────── AuditLog ────────────────────────────

model AuditLog {
  id            String      @id @default(cuid())
  actor         User        @relation(fields: [actorId], references: [id])
  actorId       String
  action        AuditAction
  resource      String
  resourceId    String?
  diff          Json?
  ip            String?
  /// Links to OperationLog.correlationId — set for SSH-related actions
  correlationId String?
  timestamp     DateTime    @default(now())

  @@index([actorId])
  @@index([timestamp])
  @@index([correlationId])
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  DEPLOY
  ROLLBACK
  SSH_TEST
}

// ──────────────────────────── OperationLog ────────────────────────────

model OperationLog {
  id            String   @id @default(cuid())
  /// Resource type — e.g. 'node', 'server', any future resource
  resourceType  String
  /// Nullable — resource may be deleted but log must persist
  resourceId    String?
  /// Denormalised resource name — survives resource deletion
  resourceName  String
  /// Nullable — system-triggered operations have no human actor
  actorId       String?
  /// Flexible operation name — e.g. 'DEPLOY', 'UNDEPLOY', any future operation
  operation     String
  /// Links to AuditLog.correlationId for join queries
  correlationId String?
  success       Boolean
  /// Full log text (newline-separated)
  log           String?
  /// Duration in milliseconds
  durationMs    Int?
  createdAt     DateTime @default(now())

  @@index([resourceType, resourceId])
  @@index([correlationId])
  @@index([createdAt])
}

// ──────────────────────────── Pipeline (CI/CD) ────────────────────────────

model Pipeline {
  id             String   @id @default(cuid())
  name           String
  repoUrl        String
  branch         String   @default("main")
  /// AES-GCM encrypted GitHub Personal Access Token (optional, for private repos)
  githubTokenEnc String?
  /// HMAC-SHA256 secret for GitHub webhook validation
  webhookSecret  String
  /// Absolute path on VPS where repo will be cloned
  workDir        String   @default("/opt/apps")
  buildCommands  String[]
  deployCommands String[]
  /// Target server IDs
  serverIds      String[]
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  runs PipelineRun[]
}

model PipelineRun {
  id         String            @id @default(cuid())
  pipeline   Pipeline          @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  pipelineId String
  trigger    PipelineTrigger   @default(MANUAL)
  status     PipelineRunStatus @default(PENDING)
  commitSha  String?
  commitMsg  String?
  branch     String?
  log        String?
  startedAt  DateTime?
  endedAt    DateTime?
  createdAt  DateTime          @default(now())

  @@index([pipelineId, createdAt])
}

enum PipelineTrigger {
  MANUAL
  WEBHOOK
}

enum PipelineRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}
