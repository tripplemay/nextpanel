{
  "name": "nextpannel",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "sh -c '(nc -z localhost 5433 2>/dev/null || (ssh -N -f nextpanel-db && sleep 1)) && pnpm --parallel -r dev'",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "cpu-features",
      "prisma",
      "sharp",
      "ssh2"
    ]
  }
}
